{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "README.md"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      { "source": "/home", "destination": "/index.html" },
      { "source": "/register", "destination": "/register.html" },
      { "source": "/course", "destination": "/course.html" },
      { "source": "/dashboard", "destination": "/dashboard.html" }
    ]
  }
}
