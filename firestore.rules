rules_version = '2';
// ─────────────────────────────────────────────────────────────────────────────
// CI Minds — Firestore Security Rules
// Version: 3.0 — Merged production rules
//
// Covers:
//   users/{uid}                  — profile, enrollment, session, progress
//   users/{uid}/payments/{id}    — immutable payment records
//   registrations/{uid}          — seat-reservation (register.html ₹7 flow)
//
// Key protections:
//   • Only authenticated owner can read/write their own documents
//   • enrolled / paymentId / enrolledAt can NEVER be set by the client
//   • Payment records are immutable after creation
//   • Registrations are write-once per user (server-enforced)
//   • Admin UID can read all documents for support
//   • Catch-all deny blocks all other collections
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isAdmin() {
      return request.auth != null && request.auth.uid in [
        'REPLACE_WITH_YOUR_ADMIN_UID'
        // add more admin UIDs here if needed
      ];
    }

    // Prevents the client from ever touching enrollment fields.
    // Only the Cloud Function (server-side) can write these.
    function doesNotTouchEnrollmentFields() {
      return !('enrolled'   in request.resource.data) &&
             !('paymentId'  in request.resource.data) &&
             !('enrolledAt' in request.resource.data);
    }

    // ── users/{userId} ───────────────────────────────────────────────────────
    // Profile, enrollment status, course progress, session tracking.
    match /users/{userId} {

      // Read: only owner or admin
      allow read: if isOwner(userId) || isAdmin();

      // Create: owner can create their own doc but cannot set enrollment fields
      allow create: if isOwner(userId) && doesNotTouchEnrollmentFields();

      // Update: owner can update session/progress fields only
      // They can NEVER elevate their own enrolled status
      allow update: if isOwner(userId) && doesNotTouchEnrollmentFields();

      // Delete: nobody except admin (prevents enrollment bypass by delete+recreate)
      allow delete: if isAdmin();

      // ── users/{userId}/payments/{paymentId} ──────────────────────────────
      // Immutable once written — create and read only, no edit or delete.
      match /payments/{paymentId} {
        allow read: if isOwner(userId) || isAdmin();

        // Client can create a payment record (as backup to Cloud Function)
        // but must include required fields and correct uid
        allow create: if isOwner(userId) &&
                         request.resource.data.keys().hasAll([
                           'razorpay_payment_id', 'amount', 'currency', 'uid'
                         ]) &&
                         request.resource.data.uid == userId &&
                         request.resource.data.amount > 0;

        // Immutable — no edits or deletes ever (except admin)
        allow update, delete: if isAdmin();
      }
    }

    // ── registrations/{userId} ───────────────────────────────────────────────
    // The ₹7 seat-reservation record from register.html.
    // Fully separate from "users" (enrollment) — intentionally.
    //
    // SERVER-SIDE RATE LIMIT:
    //   !exists(...) means Firestore rejects any create if a doc already exists.
    //   Combined with allow update: if false, double-registration is physically
    //   impossible — even if someone bypasses all client-side checks.
    match /registrations/{userId} {
      allow read, create: if isOwner(userId) &&
                             !exists(/databases/$(database)/documents/registrations/$(userId));
      allow update, delete: if false;
      allow read: if isAdmin();
    }

    // ── security_events (written by Cloud Function for fraud monitoring) ─────
    match /security_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false; // only Cloud Function writes here
    }

    // ── Catch-all deny ───────────────────────────────────────────────────────
    // Blocks scrapers probing unknown collection paths, bots brute-forcing
    // document paths, and accidental exposure from new collections added
    // without explicit rules.
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
