// CBK Innovative Minds — Firestore Security Rules
// Version: 2.0
// Last updated: 2026
//
// CRITICAL RULES:
// 1. 'enrolled' field can NEVER be written by the client.
//    Only the Cloud Function (verifyPayment) writes it.
// 2. Users can only read/write their OWN documents.
// 3. Progress data is user-owned but enrolled status is server-only.
// 4. Admin collection is read-only from client (write via Cloud Functions only).

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User documents ────────────────────────────────────────────────────────
    match /users/{userId} {

      // Allow a user to READ their own document only
      allow read: if request.auth != null && request.auth.uid == userId;

      // Allow a user to CREATE their own document (first sign-in)
      // BUT they cannot set enrolled, foundingMember, or paymentId themselves
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && !('enrolled'       in request.resource.data)
                    && !('foundingMember' in request.resource.data)
                    && !('paymentId'      in request.resource.data);

      // Allow a user to UPDATE their own document
      // BUT they cannot modify enrolled, foundingMember, or paymentId
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !('enrolled'       in request.resource.data.diff(resource.data).affectedKeys())
                    && !('foundingMember' in request.resource.data.diff(resource.data).affectedKeys())
                    && !('paymentId'      in request.resource.data.diff(resource.data).affectedKeys());

      // Nobody can delete user documents from the client
      allow delete: if false;
    }

    // ── Progress sub-collection (if used separately) ──────────────────────────
    match /progress/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Admin collection — read-only from client, write from Cloud Functions ──
    match /admin/{document=**} {
      allow read:  if request.auth != null && isAdmin(request.auth.token.email);
      allow write: if false; // Only Cloud Functions write here
    }

    // ── Everything else — deny by default ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helper: admin email check ─────────────────────────────────────────────
    // Add your admin email(s) here
    function isAdmin(email) {
      return email in [
        // 'yourname@gmail.com'  ← ADD YOUR EMAIL
      ];
    }
  }
}
